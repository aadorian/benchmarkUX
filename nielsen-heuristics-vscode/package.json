{
  "name": "nielsen-heuristics",
  "displayName": "Nielsen Heuristics — Usability Violation Highlighter",
  "description": "Highlights usability violations in HTML/CSS/JS files based on Nielsen's 10 heuristics. Get inline diagnostics, a scored report panel, and concrete fix suggestions — without leaving your editor.",
  "version": "0.1.0",
  "publisher": "findapaw",
  "license": "MIT",
  "engines": { "vscode": "^1.74.0" },
  "categories": ["Linters", "Education", "Other"],
  "keywords": [
    "usability", "ux", "nielsen", "heuristics",
    "accessibility", "wcag", "linter", "html", "ui-review"
  ],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1E1E3F",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/findapaw/nielsen-heuristics-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/findapaw/nielsen-heuristics-vscode/issues"
  },
  "homepage": "https://github.com/findapaw/nielsen-heuristics-vscode#readme",
  "badges": [
    {
      "url": "https://img.shields.io/visual-studio-marketplace/v/findapaw.nielsen-heuristics.svg",
      "href": "https://marketplace.visualstudio.com/items?itemName=findapaw.nielsen-heuristics",
      "description": "VS Marketplace Version"
    },
    {
      "url": "https://img.shields.io/visual-studio-marketplace/d/findapaw.nielsen-heuristics.svg",
      "href": "https://marketplace.visualstudio.com/items?itemName=findapaw.nielsen-heuristics",
      "description": "VS Marketplace Downloads"
    }
  ],
  "activationEvents": [
    "onLanguage:html",
    "onLanguage:css",
    "onLanguage:javascript",
    "onCommand:nielsen.reviewFile",
    "onCommand:nielsen.reviewSelection"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "nielsen.reviewFile",
        "title": "Nielsen: Review File for Usability Violations",
        "category": "Nielsen"
      },
      {
        "command": "nielsen.reviewSelection",
        "title": "Nielsen: Review Selected Code",
        "category": "Nielsen"
      },
      {
        "command": "nielsen.clearDiagnostics",
        "title": "Nielsen: Clear All Diagnostics",
        "category": "Nielsen"
      },
      {
        "command": "nielsen.showReport",
        "title": "Nielsen: Show Report Panel",
        "category": "Nielsen"
      }
    ],
    "keybindings": [
      {
        "command": "nielsen.reviewFile",
        "key": "ctrl+shift+u",
        "mac": "cmd+shift+u",
        "when": "editorTextFocus"
      },
      {
        "command": "nielsen.reviewSelection",
        "key": "ctrl+shift+alt+u",
        "mac": "cmd+shift+alt+u",
        "when": "editorHasSelection"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "nielsen.reviewFile",
          "group": "nielsen@1",
          "when": "resourceLangId =~ /html|css|javascript/"
        },
        {
          "command": "nielsen.reviewSelection",
          "group": "nielsen@2",
          "when": "editorHasSelection && resourceLangId =~ /html|css|javascript/"
        }
      ]
    },
    "configuration": {
      "title": "Nielsen Heuristics",
      "properties": {
        "nielsen.reviewOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically run the Nielsen review when a HTML/CSS/JS file is saved."
        },
        "nielsen.showReportPanel": {
          "type": "boolean",
          "default": true,
          "description": "Open the report panel automatically after a review."
        }
      }
    }
  }
}
